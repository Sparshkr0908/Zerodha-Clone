# Dependency directories (Never commit these)
node_modules/
jspm_packages/
web_modules/

# Local environment files (Contains passwords, keys, and API secrets)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Log files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs (Uncomment if you use TypeScript, Babel, or Next.js)
# dist/
# build/
# .next/
# out/

# Diagnostic reports and runtime outputs
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids
*.pid
*.seed
*.pid.lock

# Testing and coverage outputs
coverage/
.nyc_output

# IDE, Editors, and OS-specific files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
